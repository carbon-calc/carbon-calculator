@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix calc:  <https://data.carbon-calculator.co.uk/ontologies/calculation#> .
@prefix proj:  <https://data.carbon-calculator.co.uk/ontologies/project#> .
@prefix eco:   <https://data.carbon-calculator.co.uk/ontologies/ecology#> .

# =============================================================================
# Reference Data — Soil Carbon Emission Lookup
# =============================================================================
# Each entry provides soil carbon emissions (tCO2e/ha) for a specific
# country and topsoil carbon loss percentage, broken down by previous landuse.
# =============================================================================

calc:soilEmissionEngland00
    a calc:SoilEmissionLookupEntry ;
    rdfs:label "Soil emission: England, 00% topsoil lost"@en ;
    calc:soilEmissionCountry proj:England ;
    calc:topsoilPercentageCode "00" ;
    calc:hasSoilEmissionRate calc:soilRateEngland00Seminatural ;
    calc:hasSoilEmissionRate calc:soilRateEngland00Pasture ;
    calc:hasSoilEmissionRate calc:soilRateEngland00Arable .

calc:soilRateEngland00Seminatural
    a calc:SoilEmissionRate ;
    rdfs:label "Soil rate: England, 00%, Seminatural"@en ;
    calc:forPreviousLanduse eco:Seminatural ;
    calc:soilEmissionValue 0 .

