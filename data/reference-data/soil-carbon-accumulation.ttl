@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix calc:  <https://data.carbon-calculator.co.uk/ontologies/calculation#> .
@prefix proj:   <https://data.carbon-calculator.co.uk/ontologies/project#> .

# =============================================================================
# Reference Data — Soil Carbon Accumulation Rates
# =============================================================================
# Cumulative tCO2e/ha for previously-arable mineral soil under
# minimum-intervention management, indexed by growth period.
# =============================================================================

calc:soilAccum0_5
    a calc:SoilCarbonAccumulationRate ;
    rdfs:label "Soil C accumulation: 0-5"@en ;
    calc:accumulationForPeriod proj:period0to5 ;
    calc:accumulationValue 2.75 .

