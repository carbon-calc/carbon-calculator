@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix eco:   <https://data.carbon-calculator.co.uk/ontologies/ecology#> .

# =============================================================================
# Reference Data — Regeneration Types
# =============================================================================

eco:BroadleavesRegen
    a eco:RegenerationType ;
    rdfs:label "Broadleaves"@en .

eco:ScotsPineRegen
    a eco:RegenerationType ;
    rdfs:label "Scots Pine"@en .

eco:BothRegen
    a eco:RegenerationType ;
    rdfs:label "Both"@en .
