@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix eco:   <https://data.carbon-calculator.co.uk/ontologies/ecology#> .

# =============================================================================
# Reference Data — Management Regimes
# =============================================================================

eco:NoThin
    a eco:ManagementRegime ;
    rdfs:label "No Thinning"@en ;
    eco:managementRegimeCode "No_thin" .

eco:Thinned
    a eco:ManagementRegime ;
    rdfs:label "Thinned"@en ;
    eco:managementRegimeCode "Thinned" .
