@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix eco:   <https://data.carbon-calculator.co.uk/ontologies/ecology#> .

# =============================================================================
# Reference Data — Species Model Groups
# =============================================================================
# Each model group has valid spacing options and yield classes.
# =============================================================================

eco:modelGroupBE
    a eco:SpeciesModelGroup ;
    rdfs:label "Model Group BE"@en ;
    eco:speciesModelCode "BE" ;
    eco:hasAvailableSpacing eco:spacing1p2 ;
    eco:hasAvailableSpacing eco:spacing2p5 ;
    eco:hasAvailableSpacing eco:spacing3p0 ;
    eco:hasAvailableSpacing eco:spacing4p0 ;
    eco:hasAvailableSpacing eco:spacing5p0 ;
    eco:hasAvailableYieldClass eco:yieldClass2 ;
    eco:hasAvailableYieldClass eco:yieldClass4 ;
    eco:hasAvailableYieldClass eco:yieldClass6 ;
    eco:hasAvailableYieldClass eco:yieldClass8 ;
    eco:hasAvailableYieldClass eco:yieldClass10 .

