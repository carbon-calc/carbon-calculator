@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix eco:   <https://data.carbon-calculator.co.uk/ontologies/ecology#> .
@prefix qty:   <https://data.carbon-calculator.co.uk/ontologies/quantity#> .

# =============================================================================
# Reference Data — Tree Spacing Options with Emission Rates
# =============================================================================
# Rates are in tCO2e per hectare (negative = emissions).
# Shelter rates are for 1.2m tree shelters.
# Spiral guard rates are for 0.6m spiral guards.
# =============================================================================

eco:spacing1p2
    a eco:TreeSpacingOption ;
    rdfs:label "1.2m spacing"@en ;
    eco:spacingValue 1.2 ;
    eco:seedlingRate -1.0416666666666667 ;
    eco:voleguardRate -2.152777777777778 ;
    eco:fertiliserRate -0.10902777777777779 ;
    eco:hasShelterRate eco:shelter1p2_1p2m ;
    eco:hasSpiralGuardRate eco:spiral1p2_0p6m .

eco:shelter1p2_1p2m
    a eco:ShelterRate ;
    rdfs:label "Shelter rate at 1.2m spacing, 1.2m height"@en ;
    eco:protectionEmissionRate -59.097222222222236 .

eco:spiral1p2_0p6m
    a eco:SpiralGuardRate ;
    rdfs:label "Spiral guard rate at 1.2m spacing, 0.6m height"@en ;
    eco:protectionEmissionRate -7.7777777777777795 .

