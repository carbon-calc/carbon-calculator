{
  "@context": {
    "proj": "https://data.carbon-calculator.co.uk/ontologies/project#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "qty": "https://data.carbon-calculator.co.uk/ontologies/quantity#",
    "label": "rdfs:label",
    "comment": "rdfs:comment",
    "emissionRate": {
      "@id": "proj:emissionRate",
      "@type": "http://www.w3.org/2001/XMLSchema#double"
    },
    "emissionRateUnit": {
      "@id": "proj:emissionRateUnit",
      "@type": "@id"
    }
  },
  "@graph": [
    {
      "@id": "proj:SeedlingEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Seedlings",
      "comment": "Spacing-dependent rate \u2014 looked up via eco:TreeSpacingOption eco:seedlingRate."
    },
    {
      "@id": "proj:TreeShelterEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Tree protection - Tree shelters",
      "comment": "Spacing-dependent rate \u2014 looked up via eco:TreeSpacingOption eco:hasShelterRate."
    },
    {
      "@id": "proj:SpiralGuardEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Tree protection - Spiral guards",
