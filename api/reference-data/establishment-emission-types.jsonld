      "label": "Ground preparation (fuel): Scarifying",
      "emissionRate": -0.05185,
      "emissionRateUnit": "qty:hectare"
    },
    {
      "@id": "proj:PloughingEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Ground preparation (fuel): Ploughing",
      "emissionRate": -0.06874,
      "emissionRateUnit": "qty:hectare"
    },
    {
      "@id": "proj:SubsoilingEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Ground preparation (fuel): Subsoiling",
      "emissionRate": -0.17296,
      "emissionRateUnit": "qty:hectare"
    },
    {
      "@id": "proj:HerbicideEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Herbicide",
      "emissionRate": -0.04414,
