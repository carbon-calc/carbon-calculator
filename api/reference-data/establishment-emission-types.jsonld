    },
    {
      "@id": "proj:VoleguardEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Tree protection - Voleguards",
      "comment": "Spacing-dependent rate \u2014 looked up via eco:TreeSpacingOption eco:voleguardRate."
    },
    {
      "@id": "proj:FertiliserEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Fertiliser",
      "comment": "Spacing-dependent rate \u2014 looked up via eco:TreeSpacingOption eco:fertiliserRate."
    },
    {
      "@id": "proj:MoundingEmission",
