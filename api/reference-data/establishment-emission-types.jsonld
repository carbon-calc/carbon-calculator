      "emissionRateUnit": "qty:metre"
    },
    {
      "@id": "proj:GateEmission",
      "@type": "proj:EstablishmentEmissionType",
      "label": "Gates",
      "emissionRate": -0.583,
      "emissionRateUnit": "qty:each"
    },
    {
      "@id": "proj:RoadBuildingEmission",
      "@type": "proj:EstablishmentEmissionType",
